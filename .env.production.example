# Production template. `make setup` creates .env from this shape and generates
# strong secrets automatically. Edit values such as APP_PORT, BETTER_AUTH_URL,
# WEB_ORIGIN, and transcription provider keys after setup.

APP_PORT=8080
PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_HOST_PORT=9000
MINIO_CONSOLE_PORT=9001

POSTGRES_USER=openminutes
POSTGRES_PASSWORD=change-me
POSTGRES_DB=openminutes
DATABASE_URL=postgres://openminutes:change-me@postgres:5432/openminutes

REDIS_URL=redis://redis:6379

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=recordings

BETTER_AUTH_SECRET=change-me
BETTER_AUTH_URL=http://localhost:8080
WEB_ORIGIN=http://localhost:8080
INTERNAL_TOKEN=change-me

BOT_IMAGE=openminutes-bot:prod
BOT_NETWORK=openminutes-net
BOT_VNC_MODE=network
API_URL_FOR_BOTS=http://api:3000
MINIO_ENDPOINT_FOR_BOTS=minio

DEEPGRAM_API_KEY=
DEEPGRAM_LANGUAGE=id

BROWSER_STEALTH=off
CHROMIUM_FAKE_MEDIA=true
FAKE_MEDIA_DIR=/app/assets
JOIN_TIMEOUT_SEC=300
MAX_DURATION_MIN=180
TZ=Asia/Jakarta
