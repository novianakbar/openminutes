# Semua nilai di bawah adalah default dev — kode punya fallback yang sama,
# jadi file ini opsional untuk pengembangan lokal.

PORT=3000
DATABASE_URL=postgres://openminutes:openminutes@localhost:5432/openminutes
REDIS_URL=redis://localhost:6379

# MinIO (lihat docker-compose.yml)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET=recordings

# Auth (better-auth) — WAJIB ganti secret di production (openssl rand -base64 32)
BETTER_AUTH_SECRET=dev-secret-ganti-di-production-min-32-karakter!
BETTER_AUTH_URL=http://localhost:3000
WEB_ORIGIN=http://localhost:5173

# Token bersama antara API dan kontainer bot (ganti di production)
INTERNAL_TOKEN=dev-internal-token

# Image bot yang di-spawn bot manager
BOT_IMAGE=openminutes-bot:dev
# Mode dev default: API berjalan di host, VNC bot dipublish ke loopback host.
# Production full Docker pakai:
#   BOT_IMAGE=openminutes-bot:prod
#   BOT_NETWORK=openminutes-net
#   BOT_VNC_MODE=network
BOT_NETWORK=
BOT_VNC_MODE=host
# URL API yang bisa dijangkau DARI DALAM kontainer bot (Docker Desktop mac/win)
API_URL_FOR_BOTS=http://host.docker.internal:3000
MINIO_ENDPOINT_FOR_BOTS=host.docker.internal

# Transkripsi — konfigurasi utama ada di UI admin (halaman Transcription,
# tersimpan di tabel app_settings). Env di bawah hanya fallback saat settings
# belum diisi. Tanpa keduanya, rekaman tetap tersimpan tapi transkripsi
# dilewati (status transcription_skipped).
DEEPGRAM_API_KEY=
DEEPGRAM_LANGUAGE=id

# Bot browser tuning
# Default yang paling stabil saat ini: Playwright vanilla + patch fingerprint
# minimal manual. Aktifkan full stealth hanya untuk eksperimen/fallback:
#   BROWSER_STEALTH=zoom
#   BROWSER_STEALTH=all
BROWSER_STEALTH=off

# Fake media Chromium menyediakan mic/kamera stabil untuk layar pre-join.
# Default kode: true. Matikan hanya untuk diagnosis device media:
#   CHROMIUM_FAKE_MEDIA=off
CHROMIUM_FAKE_MEDIA=true

# Lokasi silence.wav dan black.y4m di image bot.
FAKE_MEDIA_DIR=/app/assets

# Batas waktu join dan durasi maksimum sesi bot.
JOIN_TIMEOUT_SEC=300
MAX_DURATION_MIN=180

# Timezone browser bot.
TZ=Asia/Jakarta
